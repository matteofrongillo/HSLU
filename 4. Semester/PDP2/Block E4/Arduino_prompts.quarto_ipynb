        "// ===================== MAIN LOOP =====================\n",
        "void loop() {\n",
        "  currentMotorPosition = 0;\n",
        "\n",
        "  delay(500);\n",
        "\n",
        "  // ---------- Sweep Forward 0 -> X ----------\n",
        "  for (int i = 0; i < SWEEP_STEPS; i++) {\n",
