        "\n",
        "  // ---------- Sweep Backward X -> 0 ----------\n",
        "  for (int i = 0; i < SWEEP_STEPS; i++) {\n",
        "    Motor.StepperRun(-1, 0, 0);\n",
        "    currentMotorPosition--;\n",
        "\n",
        "    // TODO:\n",
        "    // - same logic as forward sweep\n",
        "    // - keep angle tracking consistent\n",
        "\n",
